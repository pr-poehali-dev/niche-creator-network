{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "No token forbidden",
      "method": "GET",
      "path": "/",
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST without token forbidden",
      "method": "POST",
      "path": "/",
      "body": {"slug": "morozov", "licenseVerified": true},
      "expectedStatus": 403,
      "expectedBody": {"error": "forbidden"},
      "bodyMatcher": "partial"
    }
  ]
}
