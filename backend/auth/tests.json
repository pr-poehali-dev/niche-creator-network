{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Register weak password rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "weaktest@example.com", "password": "123", "role": "client"},
      "expectedStatus": 400
    },
    {
      "name": "Login invalid credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "nouser@example.com", "password": "whatever123"},
      "expectedStatus": 401
    },
    {
      "name": "Me without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {"action": "foobar"},
      "expectedStatus": 400
    }
  ]
}
