{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Register weak password rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "weaktest@example.com", "password": "123", "role": "client"},
      "expectedStatus": 400
    },
    {
      "name": "Register without consent rejected",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "noconsent@example.com", "password": "strongpass123", "role": "client"},
      "expectedStatus": 400,
      "expectedBody": {"error": "consent"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login invalid credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "nouser@example.com", "password": "whatever123"},
      "expectedStatus": 401
    },
    {
      "name": "Me without token",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401
    },
    {
      "name": "Unknown action",
      "method": "POST",
      "path": "/",
      "body": {"action": "foobar"},
      "expectedStatus": 400
    },
    {
      "name": "Admin login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "admin_login", "password": "definitely-wrong-pass", "role": "client"},
      "expectedStatus": 401
    }
  ]
}