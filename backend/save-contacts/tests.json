      "path": "/",
      "body": {"slug": "morozov", "phone": "+74951234567", "email": "a.morozov@securenet.ru", "whatsapp": "+74951234567", "telegram": "morozov_polygraph", "website": "https://securenet.ru/morozov"},
      "expectedStatus": 200
    }
  ]
}
