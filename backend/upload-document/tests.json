{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Invalid ext returns 400",
      "method": "POST",
      "path": "/",
      "body": {"slug": "morozov", "fileBase64": "iVBORw0KGgo=", "ext": "exe"},
      "expectedStatus": 400
    },
    {
      "name": "Empty file returns 400",
      "method": "POST",
      "path": "/",
      "body": {"slug": "morozov", "fileBase64": "", "ext": "pdf"},
      "expectedStatus": 400
    }
  ]
}
